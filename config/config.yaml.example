spring:
  task:
    scheduling:
      # Unit tests / Codex: don't run @Scheduled jobs
      enabled: false

# ====== VEZHA API ======
vezha:
  api:
    # Keep unreachable to prevent accidental calls from tests
    base-url: "http://127.0.0.1:9/api"
    token: "DUMMY"

  cafe:
    # Linux-safe path
    output-dir: "/tmp/reports/cafeteria"
    analytics-ids: [2]
    timezone: "UTC"
    schedule-cron: "0 0 22 * * *"
    excluded-list-names: ["outsourced"]


  db:
    enabled: false
    host: "localhost"
    port: "5432"
    database: "videoanalytics"
    schema: "videoanalytics"
    username: "postgres"
    password: "postgres"

# ====== Telegram ======
telegram:
  bot:
    # Set to false to temporarily disable long-polling when DNS/network to api.telegram.org is unavailable.
    enabled: true
    token: "DUMMY"
    username: "dummy_bot"

# ====== Evacuation ======
evacuation:
  # For Codex/unit tests: keep disabled by default
  enabled: false
  autostart: false
  lookbackDays: 14
  refreshMinutes: 5

# ====== Unknown ======
unknown:
  # matches @ConfigurationProperties(prefix="unknown")
  autostart: false
  # camera frame height in pixels (used for detection box -> pixel conversion)
  camera-resolution-height: 1080
  # minimum acceptable face box height in pixels for auto-generated unknowns
  desired-image-height: 120

# ====== PostgreSQL ======
postgres:
  # Linux client path (only relevant if you ever enable DB init)
  psqlPath: "/usr/bin/psql"
  superuser: "postgres"
  superpass: "postgres"

  # blank => skip DB init logic in tests
  database: ""
